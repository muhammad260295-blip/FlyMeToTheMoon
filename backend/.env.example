# https://serpapi.com/ — Google Flights API (engine=google_flights)
# Server-only: copy to backend/.env (gitignored). Never commit real keys.
# If a key leaks, revoke/rotate it in the SerpAPI dashboard immediately.
SERPAPI_KEY=

# API listen port (default 3001)
# PORT=3001

# Comma-separated browser origins allowed for CORS (production).
# Example: https://your-app.vercel.app,https://www.yourdomain.com
# Omit to allow any origin (OK for local dev; tighten in production).
# ALLOWED_ORIGINS=

# Optional tuning (see backend search/SerpAPI code)
# SERPAPI_TIMEOUT_MS=25000
# FLIGHT_SEARCH_MAX_OUTBOUND_DATES=21
# FLIGHT_SEARCH_CONCURRENCY=4
# FLIGHT_SEARCH_CACHE_TTL_MS=60000
